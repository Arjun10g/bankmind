# BankMind environment variables — copy to .env and fill in values.
# Never commit .env (already in .gitignore).

# === LLM (Anthropic only — all other models are open-source and run locally) ===
ANTHROPIC_API_KEY=

# === Qdrant (vector DB — open-source, replaces Supabase pgvector) ===
# Sign up at https://cloud.qdrant.io for a free 1GB cluster.
# QDRANT_URL example: https://xxxxx.us-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_URL=
QDRANT_API_KEY=
# Collection prefix — names will be "{prefix}_{module}_{strategy}" (e.g.
# "bankmind_compliance_semantic"). Override only for a separate environment.
QDRANT_COLLECTION_PREFIX=bankmind

# === Hugging Face ===
# Optional unless you need gated models. Public models work without a token.
HUGGINGFACE_TOKEN=

# === FRED (macro time series) ===
# Free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# === SEC EDGAR ===
# Required header on every EDGAR request. Format: "Name email@example.com".
SEC_USER_AGENT="BankMind Research your-email@example.com"

# === Open-source model selection ===
# Default embedding model is Matryoshka-trained for these dims:
#   [128, 256, 512, 768, 1024]  — see pipelines/shared/embedder.py
EMBEDDING_MODEL=mixedbread-ai/mxbai-embed-large-v1
SPLADE_MODEL=naver/splade-cocondenser-ensembledistil
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
COLBERT_MODEL=colbert-ir/colbertv2.0
MONOT5_MODEL=castorini/monot5-base-msmarco

# === Observability (optional, Phase 10) ===
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=bankmind
LANGSMITH_TRACING=false
